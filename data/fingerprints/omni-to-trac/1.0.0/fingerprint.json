      "id": "FM-001",
      "impact": 0.9,
      "name": "Loan outstanding-balance carry-over",
      "origin": "seed:experience",
      "probability": 0.6,
      "remediation": "Recompute amortization from origination; verify payment application order and accrual basis on the target.",
      "sample_defect": "Loan L2 target outstanding balance 10398.55 vs source 10432.17 (delta -33.62) after a payment was applied out of order.",
      "seed_probability": null
    },
    {
